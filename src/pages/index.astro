                                <div class="pricing-header">
                                    <span class="pricing-label">Starting Price</span>
                                    <span class="pricing-amount">₹3,000</span>
                                </div>
                                <div class="pricing-details">
                                    <div class="pricing-row">
                                        <span>Typical Timeline</span>
                                        <span>1-2 weeks</span>
                                    </div>
                                    <div class="pricing-row">
                                        <span>Deliverables</span>
                                        <span>Animated video, source files</span>
                                    </div>
                                </div>
                            </div>

                            <div class="service-case-study">
                                <div class="case-study-header">Case Study</div>
                                <div class="case-study-grid">
                                    <div class="case-study-item">
                                        <div class="case-study-label">The Problem</div>
                                        <p class="case-study-text">Brand needed impactful storytelling for product launch campaign.</p>
                                    </div>
                                    <div class="case-study-item">
                                        <div class="case-study-label">Our Process</div>
                                        <p class="case-study-text">Conceptualized narrative, 4K production, color grading, sound design.</p>
                                    </div>
                                    <div class="case-study-item">
                                        <div class="case-study-label">The Result</div>
                                        <p class="case-study-text case-study-result">500K+ views, 40% increase in product inquiries within first week.</p>
                                    </div>
                                </div>
                            </div>

                            <a href="#contact" class="service-cta">Animate Your Vision</a>
                        </div>
                        <div class="service-visual">
                            <div class="service-image-grid">
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1628494391268-c9935bc384d5??w=400&h=600&fit=crop" alt="Motion Graphics">
                                </div>
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1550745165-9bc0b252726f?w=400&h=300&fit=crop" alt="3D Animation">
                                </div>
                                <div class="service-image">
                                    <img src="2.png" alt="Visual Effects">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Photography Section -->
                <div class="service-section">
                    <div class="service-container">
                        <div class="service-content">
                            <div class="service-number">05</div>
                            <h3 class="service-title">Professional Photography</h3>
                            <p class="service-description">
                                Capture moments that matter with our professional photography services. 
                                From portraits to products, we deliver images that leave lasting impressions.
                            </p>
                            <ul class="service-features">
                                <li>Portrait Photography</li>
                                <li>Product Photography</li>
                                <li>Commercial Shoots</li>
                                <li>Event Photography</li>
                                <li>Architectural Photography</li>
                            </ul>

                            <div class="service-pricing">
                                <div class="pricing-header">
                                    <span class="pricing-label">Starting Price</span>
                                    <span class="pricing-amount">₹3,000</span>
                                </div>
                                <div class="pricing-details">
                                    <div class="pricing-row">
                                        <span>Typical Timeline</span>
                                        <span>1-2 weeks</span>
                                    </div>
                                    <div class="pricing-row">
                                        <span>Deliverables</span>
                                        <span>High-resolution images</span>
                                    </div>
                                </div>
                            </div>

                            <div class="service-case-study">
                                <div class="case-study-header">Case Study</div>
                                <div class="case-study-grid">
                                    <div class="case-study-item">
                                        <div class="case-study-label">The Problem</div>
                                        <p class="case-study-text">Couple wanted authentic multi-day coverage across 3 venues with diverse cultural ceremonies.</p>
                                    </div>
                                    <div class="case-study-item">
                                        <div class="case-study-label">Our Process</div>
                                        <p class="case-study-text">3-person crew, multi-camera setup, aerial footage, same-day edit for reception screening.</p>
                                    </div>
                                    <div class="case-study-item">
                                        <div class="case-study-label">The Result</div>
                                        <p class="case-study-text case-study-result">25-min cinematic film delivered, featured on WedMeGood, 50K+ views online.</p>
                                    </div>
                                </div>
                            </div>

                            <a href="#contact" class="service-cta">Book a Shoot</a>
                        </div>
                        <div class="service-visual">
                            <div class="service-image-grid">
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1724627559656-9652a42c7e91?w=400&h=600&fit=crop" alt="Professional Photography">
                                </div>
                                <div class="service-image">
                                    <img src="1.png" alt="Portrait Session">
                                </div>
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1671019793759-077ea7536f10?w=400&h=600&fit=crop" alt="Professional Photography">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Brand Design Section -->
                <div class="service-section">
                    <div class="service-container reverse">
                        <div class="service-content">
                            <div class="service-number">06</div>
                            <h3 class="service-title">Brand Design & Identity</h3>
                            <p class="service-description">
                                Create a distinctive brand identity that resonates with your target audience. 
                                From logos to complete brand systems, we build brands that stand out.
                            </p>
                            <ul class="service-features">
                                <li>Logo Design & Branding</li>
                                <li>Visual Identity Systems</li>
                                <li>Brand Guidelines</li>
                                <li>Marketing Materials</li>
                                <li>Digital Brand Assets</li>
                            </ul>

                            <div class="service-pricing">
                                <div class="pricing-header">
                                    <span class="pricing-label">Starting Price</span>
                                    <span class="pricing-amount">₹5,000</span>
                                </div>
                                <div class="pricing-details">
                                    <div class="pricing-row">
                                        <span>Typical Timeline</span>
                                        <span>1-2 weeks</span>
                                    </div>
                                    <div class="pricing-row">
                                        <span>Deliverables</span>
                                        <span>Complete brand system</span>
