---
import Layout from '../layouts/Layout.astro';
---

<Layout>
    <!-- Intro Screen with Name -->
    <div id="intro-screen">
        <div class="intro-glow"></div>
        <div class="intro-title" id="intro-title">
            <span class="part1">VAYDRIK</span>
            <div class="dot"></div>
            <span class="part2">STUDIO</span>
        </div>
    </div>

    <!-- Black Dot Expansion Screen -->
    <div id="black-dot-screen">
        <div class="black-dot" id="black-dot"></div>
    </div>

    <!-- Main Content -->
    <div id="main-content">
        <!-- Moving Gallery Background -->
        <div class="gallery-container">
            <div class="diagonal-wrapper" id="gallery-wrapper">
                <!-- Rows will be generated by JS -->
            </div>
        </div>

        <!-- Semi-transparent Overlay -->
        <div class="overlay-mask"></div>

        <!-- Content Layer -->
        <div class="content-layer" id="content-layer">
            <!-- Navigation -->
            <nav class="nav-bar">
                <div class="logo">VAYDRIK<span>.</span>STUDIO</div>
                <div class="nav-links">
                    <a href="#home">Home</a>
                    <a href="#services">Services</a>
                    <a href="#work">Work</a>
                    <a href="#about">About</a>
                    <a href="#contact">Contact</a>
                </div>
            </nav>

            <!-- Hero Section -->
            <section class="hero" id="home">
                <h1 class="hero-title" id="hero-title">
                    CRAFTING VISUAL<br>
                    <span class="gradient">EXPERIENCES</span>
                </h1>
                <p class="hero-subtitle" id="hero-subtitle">
                    From cinematic wedding films to professional video editing, we transform moments into timeless stories. 
                    Specializing in videography, photography, motion graphics, and brand design that elevates your vision.
                </p>
                <button class="cta-button" id="cta-button">Explore Our Work</button>
                <div class="scroll-indicator" id="scroll-indicator">
                    <span>Scroll</span>
                    <div class="scroll-arrow"></div>
                </div>
            </section>

            <!-- Services Section -->
            <section class="services animated-bg" id="services">
                <div class="floating-element"></div>
                <div class="floating-element"></div>
                <div class="floating-element"></div>
                
                <div class="services-header">
                    <h2 class="section-title">OUR EXPERTISE</h2>
                    <p class="services-subtitle">We transform ideas into compelling visual experiences across multiple creative disciplines</p>
                </div>

                <!-- Wedding Videography Section -->
                <div class="service-section">
                    <div class="service-container">
                        <div class="service-content">
                            <div class="service-number">01</div>
                            <h3 class="service-title">Wedding Videography</h3>
                            <p class="service-description">
                                Preserve your special day with cinematic wedding films that capture every emotion, every detail, and every magical moment. 
                                We create timeless wedding videos that you'll treasure forever.
                            </p>
                            <ul class="service-features">
                                <li>Cinematic Wedding Films</li>
                                <li>Pre-Wedding Shoots</li>
                                <li>Traditional & Destination Weddings</li>
                                <li>Same-Day Edit Highlights</li>
                                <li>Drone Coverage</li>
                            </ul>

                            <!-- Pricing Box -->
                            <div class="service-pricing">
                                <div class="pricing-header">
                                    <span class="pricing-label">Starting Price</span>
                                    <span class="pricing-amount">₹25,000</span>
                                </div>
                                <div class="pricing-details">
                                    <div class="pricing-row">
                                        <span>Typical Timeline</span>
                                        <span>2-3 weeks</span>
                                    </div>
                                    <div class="pricing-row">
                                        <span>Deliverables</span>
                                        <span>Full film + Highlights</span>
                                    </div>
                                </div>
                            </div>

                            <!-- Case Study -->
                            <div class="service-case-study">
                                <div class="case-study-header">Case Study</div>
                                <div class="case-study-grid">
                                    <div class="case-study-item">
                                        <div class="case-study-label">The Problem</div>
                                        <p class="case-study-text">Couple wanted authentic multi-day coverage across 3 venues with diverse cultural ceremonies.</p>
                                    </div>
                                    <div class="case-study-item">
                                        <div class="case-study-label">Our Process</div>
                                        <p class="case-study-text">3-person crew, multi-camera setup, aerial footage, same-day edit for reception screening.</p>
                                    </div>
                                    <div class="case-study-item">
                                        <div class="case-study-label">The Result</div>
                                        <p class="case-study-text case-study-result">25-min cinematic film delivered, featured on WedMeGood, 50K+ views online.</p>
                                    </div>
                                </div>
                            </div>

                            <a href="#contact" class="service-cta">Book Your Wedding</a>
                        </div>
                        <div class="service-visual">
                            <div class="service-image-grid">
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1519741497674-611481863552?w=400&h=600&fit=crop" alt="Wedding Videography">
                                </div>
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1606800052052-a08af7148866?w=400&h=300&fit=crop" alt="Wedding Ceremony">
                                </div>
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1591604466107-ec97de577aff?w=400&h=300&fit=crop" alt="Wedding Coverage">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Videography & Cinematography Section -->
                <div class="service-section">
                    <div class="service-container reverse">
                        <div class="service-content">
                            <div class="service-number">02</div>
                            <h3 class="service-title">Videography & Cinematography</h3>
                            <p class="service-description">
                                We craft compelling video narratives that captivate audiences and drive results. 
                                From concept to post-production, our cinematic approach ensures every frame tells your story.
                            </p>
                            <ul class="service-features">
                                <li>Corporate & Brand Videos</li>
                                <li>Commercial Productions</li>
                                <li>Documentary Filmmaking</li>
                                <li>Event Coverage</li>
                                <li>Social Media Content</li>
                            </ul>

                            <div class="service-pricing">
                                <div class="pricing-header">
                                    <span class="pricing-label">Starting Price</span>
                                    <span class="pricing-amount">₹15,000</span>
                                </div>
                                <div class="pricing-details">
                                    <div class="pricing-row">
                                        <span>Typical Timeline</span>
                                        <span>1-2 weeks</span>
                                    </div>
                                    <div class="pricing-row">
                                        <span>Deliverables</span>
                                        <span>Edited video, source files</span>
                                    </div>
                                </div>
                            </div>

                            <div class="service-case-study">
                                <div class="case-study-header">Case Study</div>
                                <div class="case-study-grid">
                                    <div class="case-study-item">
                                        <div class="case-study-label">The Problem</div>
                                        <p class="case-study-text">Brand needed impactful storytelling for product launch campaign.</p>
                                    </div>
                                    <div class="case-study-item">
                                        <div class="case-study-label">Our Process</div>
                                        <p class="case-study-text">Conceptualized narrative, 4K production, color grading, sound design.</p>
                                    </div>
                                    <div class="case-study-item">
                                        <div class="case-study-label">The Result</div>
                                        <p class="case-study-text case-study-result">500K+ views, 40% increase in product inquiries within first week.</p>
                                    </div>
                                </div>
                            </div>

                            <a href="#contact" class="service-cta">Start Your Project</a>
                        </div>
                        <div class="service-visual">
                            <div class="service-image-grid">
                                <div class="service-image">
                                    <img src="https://plus.unsplash.com/premium_photo-1682146739433-5926577acb7a?w=400&h=600&fit=crop" alt="Video Production">
                                </div>
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1492691527719-9d1e07e534b4?w=400&h=300&fit=crop" alt="Cinematography">
                                </div>
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1634680582783-0b06ca18a449?w=400&h=300&fit=crop" alt="Film Equipment">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Professional Video Editing Section -->
                <div class="service-section">
                    <div class="service-container">
                        <div class="service-content">
                            <div class="service-number">03</div>
                            <h3 class="service-title">Professional Video Editing</h3>
                            <p class="service-description">
                                Transform your raw footage into polished, professional videos with our expert editing services. 
                                We enhance storytelling through precise cuts, color grading, sound design, and visual effects.
                            </p>
                            <ul class="service-features">
                                <li>Advanced Color Grading</li>
                                <li>Audio Mixing & Sound Design</li>
                                <li>Multi-Camera Editing</li>
                                <li>Visual Effects Integration</li>
                                <li>Fast Turnaround Times</li>
                            </ul>

                            <div class="service-pricing">
                                <div class="pricing-header">
                                    <span class="pricing-label">Starting Price</span>
                                    <span class="pricing-amount">₹2,000</span>
                                </div>
                                <div class="pricing-details">
                                    <div class="pricing-row">
                                        <span>Typical Timeline</span>
                                        <span>3-5 days</span>
                                    </div>
                                    <div class="pricing-row">
                                        <span>Deliverables</span>
                                        <span>All formats included</span>
                                    </div>
                                </div>
                            </div>

                            <div class="service-case-study">
                                <div class="case-study-header">Case Study</div>
                                <div class="case-study-grid">
                                    <div class="case-study-item">
                                        <div class="case-study-label">The Problem</div>
                                        <p class="case-study-text">YouTube channel had 40% viewer drop-off in first 30 seconds.</p>
                                    </div>
                                    <div class="case-study-item">
                                        <div class="case-study-label">Our Process</div>
                                        <p class="case-study-text">Restructured intros, dynamic cuts, motion graphics, strategic captions.</p>
                                    </div>
                                    <div class="case-study-item">
                                        <div class="case-study-label">The Result</div>
                                        <p class="case-study-text case-study-result">Watch time increased 45%, subscriber growth up 3x.</p>
                                    </div>
                                </div>
                            </div>

                            <a href="#contact" class="service-cta">Get Started</a>
                        </div>
                        <div class="service-visual">
                            <div class="service-image-grid">
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1626785774625-ddcddc3445e9?w=1000&h=600&fit=crop" alt="Video Editing" style="object-fit: cover; object-position: 30% center;">
                                </div>
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1605826832916-d0ea9d6fe71e?w=400&h=300&fit=crop" alt="Post Production">
                                </div>
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1574717024653-61fd2cf4d44d?w=400&h=300&fit=crop" alt="Editing Suite">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Motion Graphics Section -->
                <div class="service-section">
                    <div class="service-container reverse">
                        <div class="service-content">
                            <div class="service-number">04</div>
                            <h3 class="service-title">Motion Graphics & Animation</h3>
                            <p class="service-description">
                                Bring your ideas to life with stunning motion graphics and animations. 
                                We create dynamic visual experiences that engage and inform your audience.
                            </p>
                            <ul class="service-features">
                                <li>2D & 3D Animation</li>
                                <li>Logo Animations</li>
                                <li>Explainer Videos</li>
                                <li>Visual Effects (VFX)</li>
                                <li>Interactive Animations</li>
