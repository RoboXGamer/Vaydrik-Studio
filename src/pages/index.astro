                        </div>
                        <div class="service-visual">
                            <div class="service-image-grid">
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1561070791-2526d30994b5?w=400&h=600&fit=crop" alt="Brand Design">
                                </div>
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=400&h=300&fit=crop" alt="Logo Design">
                                </div>
                                <div class="service-image">
                                    <img src="https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=400&h=300&fit=crop" alt="Brand Identity">
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Process Section -->
            <section class="process-section" id="process">
                <div class="process-container">
                    <div class="process-header fade-in">
                        <p class="section-label">How We Work</p>
                        <h2 class="section-title" style="font-size: clamp(3rem, 8vw, 6rem); background: linear-gradient(135deg, #8b5cf6 0%, #d946ef 50%, #06b6d4 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 2rem;">Our Process</h2>
                        <p class="services-subtitle">A streamlined approach that transforms your ideas into impactful visual stories.</p>
                    </div>
                    
                    <div class="process-grid">
                        <div class="process-step fade-in">
                            <div class="process-number">
                                <span class="gradient-text">01</span>
                            </div>
                            <h3>Discovery</h3>
                            <p>Understanding your vision, goals, and target audience through detailed consultation.</p>
                        </div>
                        <div class="process-step fade-in">
                            <div class="process-number">
                                <span class="gradient-text">02</span>
                            </div>
                            <h3>Strategy</h3>
                            <p>Crafting a creative approach and timeline that aligns with your objectives.</p>
                        </div>
                        <div class="process-step fade-in">
                            <div class="process-number">
                                <span class="gradient-text">03</span>
                            </div>
                            <h3>Creation</h3>
                            <p>Bringing ideas to life with expert execution and attention to detail.</p>
                        </div>
                        <div class="process-step fade-in">
                            <div class="process-number">
                                <span class="gradient-text">04</span>
                            </div>
                            <h3>Delivery</h3>
                            <p>Final deliverables with revisions, optimized for your platforms.</p>
                        </div>
                    </div>
                </div>
            </section>

            <!-- Portfolio Section -->
            <section class="portfolio-section" id="work">
                <h2 class="section-title">OUR WORK</h2>
                <p class="portfolio-subtitle">Explore our diverse portfolio across different creative disciplines</p>
                
                <!-- Portfolio Tabs -->
                <div class="portfolio-tabs">
                    <button class="tab-btn active" data-tab="wedding">Weddings</button>
                    <button class="tab-btn" data-tab="video">Videography</button>
                    <button class="tab-btn" data-tab="editing">Video Editing</button>
                    <button class="tab-btn" data-tab="photo">Photography</button>
                    <button class="tab-btn" data-tab="animation">Animation</button>
                    <button class="tab-btn" data-tab="motion">Motion Graphics</button>
                    <button class="tab-btn" data-tab="design">Brand Design</button>
                </div>

                <!-- Wedding Tab -->
                <div class="tab-content active" id="wedding-tab">
                    <div class="portfolio-grid">
                        <div class="portfolio-item video-item">
                            <video loop muted playsinline>
                                <source src="https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerEscapes.mp4" type="video/mp4">
                            </video>
                            <div class="play-button"></div>
                            <div class="media-type video">Video</div>
                            <div class="portfolio-overlay">
                                <span class="portfolio-category">Wedding Film</span>
                                <h3 class="portfolio-title">Elegant Wedding Ceremony</h3>
                                <p class="portfolio-description">A beautiful celebration of love captured in cinematic detail</p>
                                <div class="portfolio-tech">
                                    <span class="tech-tag">4K Filming</span>
                                    <span class="tech-tag">Drone Shots</span>
                                </div>
                            </div>
                        </div>

                        <div class="portfolio-item video-item">
                            <video loop muted playsinline>
                                <source src="https://commondatastorage.googleapis.com/gtv-videos-bucket/sample/ForBiggerJoyrides.mp4" type="video/mp4">
                            </video>
                            <div class="play-button"></div>
                            <div class="media-type video">Video</div>
                            <div class="portfolio-overlay">
                                <span class="portfolio-category">Pre-Wedding</span>
                                <h3 class="portfolio-title">Romantic Pre-Wedding Shoot</h3>
                                <p class="portfolio-description">Capturing the couple's journey before the big day</p>
                                <div class="portfolio-tech">
                                    <span class="tech-tag">Cinematic</span>
                                    <span class="tech-tag">Color Grading</span>
                                </div>
                            </div>
