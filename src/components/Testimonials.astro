---
import { getEntry } from 'astro:content';
import TestimonialCard from './TestimonialCard.astro';

const testimonialsEntry = await getEntry('testimonials', 'testimonials-data');
const { testimonials } = testimonialsEntry!.data;
---

<!-- Testimonials Section -->
<section class="testimonials-section" id="testimonials">
    <div class="testimonials-container">
        <div class="testimonials-header fade-in">
            <p class="section-label">Testimonials</p>
            <h2 class="section-title" style="font-size: clamp(3rem, 8vw, 6rem); background: linear-gradient(135deg, #8b5cf6 0%, #ec4899 50%, #f59e0b 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; margin-bottom: 2rem;">What Clients Say</h2>
            <p class="services-subtitle">Hear from the brands and individuals we've had the pleasure of working with.</p>
        </div>
        
        <div class="testimonials-grid">
            {testimonials.map((testimonial) => (
                <TestimonialCard testimonial={testimonial} />
            ))}
        </div>
    </div>
</section>
